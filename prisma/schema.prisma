// prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ================================
// ENUMS
// ================================
//

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
}

enum StatusType {
  VERIFIED
  PENDING
  NONE
}

enum EmploymentType {
  PERMANENT
  CONTRACT
}

enum UserStatus {
  VERIFIED
  PENDING
  REJECT
  HOLD
  INACTIVE
}

enum AdminStatus {
  VERIFIED
  PENDING
  NONE
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum BalanceType {
  CREDIT
  DEBIT
}

enum AuthIdGenerationType {
  MANUAL
  AUTO
}

enum NewsType {
  GENERAL
  ANNOUNCEMENT
  ALERT
}

enum FollowUpStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum FollowUpPriority {
  LOW
  MEDIUM
  HIGH
}

enum GalleryStatus {
  ACTIVE
  INACTIVE
  SCHEDULED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RepeatType {
  DAILY
  WEEKLY
  MONTHLY
}

//
// ================================
// USERS
// ================================
//

model User {
  id String @id @default(uuid())

  username        String
  firstName       String
  lastName        String?
  fatherOrHusband String?
  gender          Gender?
  bloodGroup      BloodGroup?
  position        String?
  income          Float?
  academicQual    String?
  languages       String[]
  maritalStatus   String?
  spouseName      String?
  spousePhone     String?
  image           String?

  dob      DateTime
  phone    String
  email    String
  password String

  // KYC
  aadharCard String?
  aadharNo   String? @unique
  panCard    String?
  panNo      String? @unique

  // Nominee
  nomineeName     String?
  nomineePhone    String?
  nomineeRelation String?

  // Address
  addressLine String?
  landmark    String?
  pinCode     String?

  // Bank
  bankName      String?
  branch        String?
  accountHolder String?
  bankAccountNo String?
  ifsc          String?

  // Office - Self Relations
  referId String?

  createdById String
  companyId   String
  company     Company @relation(fields: [companyId], references: [id])
  roleId      String
  role        Role    @relation(fields: [roleId], references: [id])
  userAuthId  String?

  teamHeadId String?

  reasonForReject String?

  status          UserStatus
  passwordChanged Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  followUps         FollowUp[]
  notifications     Notification[]
  notes             Note[]
  leads             Lead[]
  reminders         Reminder[]
  requests          Request[]          @relation("UserRequests")
  requestedByMe     Request[]          @relation("UserRequestedBy")
  siteVisits        SiteVisit[]
  pushNotifications PushNotification[]

  @@index([companyId])
  @@index([roleId])
  @@index([status])
  @@index([email])
  @@index([referId])
  @@index([teamHeadId])
}

//
// ================================
// ADMIN
// ================================
//
// 1709197660415-profile.png
// 1709197660415-profile.png
// 1736320809130-cropped-image.jpg
// 1709197660415-profile.png
// 1709197660415-profile.png
// 1709197660415-profile.png
// 1709197660415-profile.png
model Admin {
  id String @id @default(uuid())

  username         String
  firstName        String?
  lastName         String?
  address          String?
  image            String?
  phone            String
  alternativePhone String?
  email            String?
  password         String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  roleId    String
  role      Role    @relation(fields: [roleId], references: [id])

  status          AdminStatus
  passwordChanged Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([roleId])
}

//
// ================================
// COMPANY
// ================================
//

model Company {
  id String @id @default(uuid())

  company String
  address String?
  img     String?
  phone   String
  email   String  @unique

  openingBalance     Float?
  openingBalanceType BalanceType?
  openingBalanceDate DateTime?

  status  CompanyStatus
  modules String[]
  domain  String?       @unique

  primaryColour   String?
  secondaryColour String?

  authIdType   AuthIdGenerationType?
  authIdPrefix String?

  companyTerm       String?
  transactionPrefix String?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  users             User[]
  admins            Admin[]
  news              News[]
  followUps         FollowUp[]
  galleries         Gallery[]
  notifications     Notification[]
  portraits         Portrait[]
  projects          Project[]
  plots             Plot[]
  highways          Highway[]
  notes             Note[]
  roles             Role[]
  showcases         Showcase[]
  pushNotifications PushNotification[]
  videos            Video[]

  @@index([status])
}

//
// ================================
// NEWS
// ================================
//

model News {
  id String @id @default(uuid())

  title       String
  description String
  date        DateTime
  time        String
  newsPicture String?
  type        NewsType

  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  source    String?
  heading   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([date])
}

//
// ================================
// FOLLOW UP
// ================================
//

model FollowUp {
  id String @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  leadName  String
  leadPhone String
  leadEmail String?
  date      DateTime
  time      String

  followUpType   String
  projectId      String?
  project        Project?         @relation(fields: [projectId], references: [id])
  followUpStatus FollowUpStatus
  priority       FollowUpPriority
  comment        String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([projectId])
  @@index([date])
}

//
// ================================
// GALLERY
// ================================
//

model Gallery {
  id String @id @default(uuid())

  fileName     String
  fileCategory String
  companyId    String
  company      Company @relation(fields: [companyId], references: [id])

  status      GalleryStatus
  scheduledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}

//
// ================================
// NOTIFICATION
// ================================
//

model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])
  title  String
  body   String

  notificationType String
  timeStamp        DateTime @default(now())

  status      String
  companyId   String
  company     Company @relation(fields: [companyId], references: [id])
  companyName String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([isRead])
  @@index([timeStamp])
}

//
// ================================
// PORTRAIT
// ================================
//

model Portrait {
  id String @id @default(uuid())

  videoTitle String
  videoName  String?
  videoLink  String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  status      String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

//
// ================================
// PHASE
// ================================
//

model Phase {
  id String @id @default(uuid())

  phaseName String?

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  plots     Plot[]

  @@index([projectId])
}

//
// ================================
// PROJECT
// ================================
//

model Project {
  id String @id @default(uuid())

  projectName        String
  projectDescription String?
  projectAddress     String

  projectImage           String?
  projectWebsiteUrl      String?
  projectVirtualViewLink String?

  layoutImage String[]
  brochures   String[]
  qrCode      String[]

  images         String[]
  highlights     String[]
  approvals      String[]
  approvalCopies String[]

  sliders String[]
  flyers  String[]
  videos  String[]

  locationHighlights String[]

  companyId String
  highwayId String
  highway   Highway @relation(fields: [highwayId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])

  latitude  String?
  longitude String?

  incentivesLevel Json?

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  followUps FollowUp[]
  plots     Plot[]
  leads     Lead[]
  phases    Phase[]

  @@index([companyId])
  @@index([highwayId])
}

//
// ================================
// PLOT
// ================================
//

model Plot {
  id String @id @default(uuid())

  phaseId      String?
  phase        Phase?  @relation(fields: [phaseId], references: [id])
  plotCategory String
  facing       String?

  sqrYards   Float
  plotNumber String

  projectName String
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])

  plotStatus String?

  customerName    String?
  customerContact String?
  customerAddress String?

  latitude  String?
  longitude String?

  plotBookingNumber String?
  plotBookingPlan   String?

  status        String
  paymentType   String?
  paymentStatus String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([phaseId])
  @@index([companyId])
  @@index([plotStatus])
}

//
// ================================
// HIGHWAY
// ================================
//

model Highway {
  id String @id @default(uuid())

  highwayName String
  highwayIcon String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]

  @@index([companyId])
}

//
// ================================
// NOTE
// ================================
//

model Note {
  id String @id @default(uuid())

  noteTitle       String
  noteDescription String?

  userId    String
  user      User    @relation(fields: [userId], references: [id])
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
}

//
// ================================
// LEAD
// ================================
//

model Lead {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  leadName    String
  leadContact String
  leadEmail   String?

  leadCity       String?
  leadOccupation String?
  leadCompany    String?

  leadAge       Int?
  gender        Gender?
  maritalStatus String?

  additionalInformation String?

  date        DateTime
  description String?

  leadSource String
  leadStatus String

  firstInteractionDate DateTime?

  leadCategory        String?
  projectInterestedIn String?
  project             Project? @relation(fields: [projectInterestedIn], references: [id])

  observations String?
  followUpDate DateTime?

  assignedTo String?
  notes      String?

  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([projectInterestedIn])
  @@index([leadStatus])
  @@index([date])
}

//
// ================================
// REMINDER
// ================================
//

model Reminder {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type         String
  description  String
  date         DateTime
  time         String
  repeat       RepeatType
  selectedDays String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

//
// ================================
// REQUEST
// ================================
//

model Request {
  id String @id @default(uuid())

  requestType String
  userId      String
  user        User   @relation("UserRequests", fields: [userId], references: [id])

  requestedById String
  requestBy     User   @relation("UserRequestedBy", fields: [requestedById], references: [id])

  requestedName String
  message       String?
  timestamp     DateTime
  status        RequestStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([requestedById])
  @@index([status])
}

//
// ================================
// SUPER ADMIN
// ================================
//

model SuperAdmin {
  id String @id @default(uuid())

  username  String  @unique
  firstName String
  lastName  String?
  address   String?
  image     String?
  phone     String
  email     String  @unique
  password  String

  role       String
  roleName   String
  userAuthId String?

  status StatusType

  passwordChanged    Boolean
  tempPassToken      String?
  tempTokenExpiredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// ROLE
// ================================
//

model Role {
  id String @id @default(uuid())

  roleName    String
  roleNo      Int?
  displayName String
  status      StatusType

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  companyName String
  modules     String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  admins    Admin[]

  @@index([companyId])
  @@index([status])
}

//
// ================================
// SHOWCASE
// ================================
//

model Showcase {
  id String @id @default(uuid())

  fileName     String
  fileCategory String
  platform     String
  companyId    String
  company      Company @relation(fields: [companyId], references: [id])

  status StatusType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

//
// ================================
// SITE VISIT
// ================================
//

model SiteVisit {
  id String @id @default(uuid())

  userId           String
  user             User     @relation(fields: [userId], references: [id])
  leadName         String
  phone            String
  date             DateTime
  time             String
  siteVisitPicture String?
  changeLog        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

//
// ================================
// PUSH NOTIFICATION
// ================================
//

model PushNotification {
  id String @id @default(uuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id])
  fcmToken      String
  lastRequest   DateTime @default(now())
  timeStamp     DateTime @default(now())
  checkActivity DateTime @default(now())
  status        String
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
}

//
// ================================
// VIDEO
// ================================
//

model Video {
  id String @id @default(uuid())

  videoTitle String
  videoName  String
  videoLink  String
  companyId  String
  company    Company @relation(fields: [companyId], references: [id])

  status      String
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

//
// ================================
// EVENT LOG
// ================================
//

model EventLog {
  id String @id @default(uuid())

  category          String
  actionBy          String
  actionDescription String

  timeStamp DateTime @default(now())
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([timeStamp])
}
