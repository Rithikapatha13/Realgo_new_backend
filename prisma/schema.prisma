
// prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ================================
// ENUMS
// ================================
//

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
}

enum StatusType {
  ACTIVE
  INACTIVE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum EmploymentType {
  PERMANENT
  CONTRACT
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  INACTIVE
}

enum AdminStatus {
  ACTIVE
  INACTIVE
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum BalanceType {
  CREDIT
  DEBIT
}

enum AuthIdGenerationType {
  MANUAL
  AUTO
}

enum NewsType {
  GENERAL
  ANNOUNCEMENT
  ALERT
}

enum FollowUpStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum FollowUpPriority {
  LOW
  MEDIUM
  HIGH
}

enum GalleryStatus {
  ACTIVE
  INACTIVE
  SCHEDULED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RepeatType {
  DAILY
  WEEKLY
  MONTHLY
}

//
// ================================
// USERS
// ================================
//

model User {
  id String @id @default(uuid())

  username        String
  firstName       String
  lastName        String
  fatherOrHusband String
  gender          Gender
  bloodGroup      BloodGroup?
  position        String?
  income          Int?
  academicQual    String?
  languages       String[]
  maritalStatus   MaritalStatus?
  spouseName      String?
  spousePhone     String?
  image           String?

  dob      DateTime
  phone    String
  email    String
  password String

  // KYC (kept unique as original)
  aadharCard String? @unique
  aadharNo   String? @unique
  panCard    String? @unique
  panNo      String? @unique

  // Nominee
  nomineeName     String?
  nomineePhone    String?
  nomineeAltPhone String?
  nomineeRelation String?
  nomineeAge      Int?
  nomineePanNo    String?
  nomineeAadhar   String?

  // Address
  addressLine String?
  landmark    String?
  pinCode     String?

  // Bank
  bankName      String?
  branch        String?
  accountHolder String?
  bankAccountNo String?
  ifsc          String?

  // Office
  referId        String?
  createdById    String?
  companyId      String?
  companyAddress String
  role           String
  userAuthId     String?
  teamHeadId     String?

  reasonForReject String?

  status          UserStatus
  passwordChanged Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// ADMIN
// ================================
//

model Admin {
  id String @id @default(uuid())

  username         String
  firstName        String
  lastName         String
  address          String?
  img              String?
  phone            String
  alternativePhone String?
  email            String
  password         String

  companyId String
  role      String

  status          AdminStatus
  passwordChanged Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// COMPANY
// ================================
//

model Company {
  id String @id @default(uuid())

  company String
  address String?
  img     String?
  phone   String
  email   String

  openingBalance     Int?
  openingBalanceType BalanceType?
  openingBalanceDate DateTime?

  status  CompanyStatus
  modules String[]
  domain  String?

  primaryColour   String?
  secondaryColour String?

  authIdType   AuthIdGenerationType
  authIdPrefix String?

  companyTerm        String?
  transactionPrefix String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// NEWS
// ================================
//

model News {
  id String @id @default(uuid())

  title       String
  description String
  date        DateTime
  time        String
  newsPicture String?
  type        NewsType

  companyId String
  source    String?
  heading   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// FOLLOW UP
// ================================
//

model FollowUp {
  id String @id @default(uuid())

  userId   String
  leadName String
  phone    String
  email    String?
  date     DateTime
  time     String

  followUpType   String
  project        String?
  followUpStatus FollowUpStatus
  priority       FollowUpPriority
  comment        String?

  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// GALLERY
// ================================
//

model Gallery {
  id String @id @default(uuid())

  fileName     String
  fileCategory String
  companyId    String

  status      GalleryStatus
  scheduledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// NOTIFICATION
// ================================
//

model Notification {
  id String @id @default(uuid())

  userId String
  title  String
  body   String

  notificationType String
  timeStamp        DateTime @default(now())

  status      String
  companyId   String
  companyName String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// PORTRAIT
// ================================
//

model Portrait {
  id String @id @default(uuid())

  videoTitle String
  videoName  String?
  videoLink  String

  companyId String

  status      String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// PHASE
// ================================
//

model Phase {
  id String @id @default(uuid())

  phaseName String
  phases    String?

  projectId String
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// PROJECT
// ================================
//

model Project {
  id String @id @default(uuid())

  projectName        String
  projectDescription String?
  projectAddress     String

  projectImage             String?
  projectWebsiteUrl        String?
  projectVirtualViewLink   String?

  layoutImage        String?
  brochures          String?
  qrCode             String?

  images              String?
  highlights          String?
  approvals           String?
  approvalCopies      String?

  sliders             String?
  flyers              String?
  videos              String?

  locationHighlights  String?

  companyId String

  latitude  String?
  longitude String?

  incentivesLevel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// PLOT
// ================================
//

model Plot {
  id String @id @default(uuid())

  phases       String?
  plotCategory String
  facing       String?

  sqrYards   Float
  plotNumber String

  projectName String
  projectId   String

  plotStatus String

  customerName    String?
  customerContact String?
  customerAddress String?

  latitude  String?
  longitude String?

  plotBookingNumber String?
  plotBookingPlan  String?

  status        String
  paymentType  String?
  paymentStatus String?

  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// HIGHWAY
// ================================
//

model Highway {
  id String @id @default(uuid())

  highwayName String
  highwayIcon String?

  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// NOTE
// ================================
//

model Note {
  id String @id @default(uuid())

  noteTitle       String
  noteDescription String?

  userId    String
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// LEAD
// ================================
//

model Lead {
  id String @id @default(uuid())

  userId String

  leadName    String
  leadContact String
  leadEmail   String?

  leadCity       String?
  leadOccupation String?
  leadCompany    String?

  leadAge        Int?
  gender         Gender?
  maritalStatus  MaritalStatus?

  additionalInformation String?

  date        DateTime
  description String?

  leadSource String
  leadStatus String

  firstInteractionDate DateTime?

  leadCategory         String?
  projectInterestedIn  String?

  observations String?
  followUpDate DateTime?

  assignedTo String?
  notes      String?

  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// REMINDER
// ================================
//

model Reminder {
  id String @id @default(uuid())

  userId       String
  type         String
  description  String
  date         DateTime
  time         String
  repeat       RepeatType
  selectedDays String?
  companyId    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// REQUEST
// ================================
//

model Request {
  id String @id @default(uuid())

  requestType   String
  userId        String
  requestedBy   String
  requestedName String
  message       String?
  timestamp     DateTime
  status        RequestStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// SUPER ADMIN
// ================================
//

model SuperAdmin {
  id String @id @default(uuid())

  username String @unique
  firstName String
  lastName  String
  address   String?
  img       String?
  phone     String
  email     String @unique
  password  String

  role       String
  roleName   String
  userAuthId String?

  status StatusType

  passwordChanged Boolean
  tempPassToken   String?
  tempTokenExpiredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// ROLE
// ================================
//

model Role {
  id String @id @default(uuid())

  roleName    String
  roleNo      Int
  displayName String
  status      StatusType

  companyId   String
  companyName String
  modules     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// SHOWCASE
// ================================
//

model Showcase {
  id String @id @default(uuid())

  fileName     String
  fileCategory String
  platform     String
  compId       String
  status       StatusType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// SITE VISIT
// ================================
//

model SiteVisit {
  id String @id @default(uuid())

  userId   String
  leadName String
  phone    String
  date     DateTime
  time     String
  siteVisitPicture String?
  companyId String
  changeLog String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// PUSH NOTIFICATION
// ================================
//

model PushNotification {
  id String @id @default(uuid())

  userId        String
  fcmToken      String
  lastRequest   DateTime @default(now())
  timeStamp     DateTime @default(now())
  checkActivity DateTime @default(now())
  status        String
  companyId     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// VIDEO
// ================================
//

model Video {
  id String @id @default(uuid())

  videoTitle String
  videoName  String
  videoLink  String
  companyId  String
  status     String
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ================================
// EVENT LOG
// ================================
//

model EventLog {
  id String @id @default(uuid())

  category          String
  actionBy          String
  actionDescription String

  timeStamp DateTime @default(now())
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
