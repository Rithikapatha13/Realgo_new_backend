generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  username          String
  firstName         String
  lastName          String?
  fatherOrHusband   String?
  gender            Gender?
  bloodGroup        BloodGroup?
  position          String?
  income            Float?
  academicQual      String?
  languages         String[]
  maritalStatus     String?
  spouseName        String?
  spousePhone       String?
  image             String?
  dob               DateTime?
  phone             String
  email             String
  password          String
  aadharCard        String?
  aadharNo          String?
  panCard           String?
  panNo             String?
  nomineeName       String?
  nomineePhone      String?
  nomineeRelation   String?
  addressLine       String?
  landmark          String?
  pinCode           String?
  city              String?
  state             String?
  country           String?
  alternativePhone  String?
  bankName          String?
  branch            String?
  accountHolder     String?
  bankAccountNo     String?
  ifsc              String?
  referId           String?
  createdById       String
  companyId         String
  roleId            String
  userAuthId        String?
  teamHeadId        String?
  reasonForReject   String?
  status            UserStatus
  passwordChanged   Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  followUps         FollowUp[]         @relation("UserFollowUps")
  leads             Lead[]             @relation("UserLeads")
  notes             Note[]             @relation("UserNotes")
  notifications     Notification[]     @relation("UserNotifications")
  pushNotifications PushNotification[] @relation("UserPushNotifications")
  reminders         Reminder[]         @relation("UserReminders")
  requestedByMe     Request[]          @relation("UserRequestedBy")
  requests          Request[]          @relation("UserRequests")
  siteVisits        SiteVisit[]        @relation("UserSiteVisits")
  company           Company            @relation(fields: [companyId], references: [id])
  role              Role               @relation(fields: [roleId], references: [id])
  transactions      Transaction[]

  // --- LEADFLOW CRM FIELDS (Safe Appends) ---
  availability       String    @default("AVAILABLE")
  isOnline           Boolean   @default(false)
  mustChangePassword Boolean   @default(true)
  lastLoginAt        DateTime?
  lastActiveAt       DateTime?
  performanceScore   Float     @default(0)

  // Relations for Leadflow Trackers
  telecallerLeads Lead[]     @relation("UserLeadsTC")
  associateLeads  Lead[]     @relation("AssociateLeads")
  assignedLeads   Lead[]     @relation("AdminAssignments")
  callLogs        CallLog[]  @relation("UserCallLogs")
  meetings        Meeting[]  @relation("UserMeetings")
  activities      Activity[] @relation("UserActivities")

  @@index([companyId])
  @@index([roleId])
  @@index([status])
  @@index([email])
  @@index([referId])
  @@index([teamHeadId])
}

model Admin {
  id               String      @id @default(uuid())
  username         String
  address          String?
  image            String?
  phone            String
  email            String?
  password         String
  status           AdminStatus
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  alternativePhone String?
  companyId        String
  firstName        String?
  lastName         String?
  fatherOrHusband  String?
  gender           Gender?
  bloodGroup       BloodGroup?
  dob              DateTime?
  aadharNo         String?
  panNo            String?
  bankName         String?
  branch           String?
  accountHolder    String?
  bankAccountNo    String?
  ifsc             String?
  nomineeName      String?
  nomineePhone     String?
  nomineeRelation  String?
  city             String?
  state            String?
  zipCode          String?
  country          String?
  isModuleHead     Boolean     @default(false)
  passwordChanged  Boolean     @default(false)
  roleId           String
  company          Company     @relation(fields: [companyId], references: [id])
  role             Role        @relation(fields: [roleId], references: [id])

  // CRM Relations
  telecallerLeads  Lead[]      @relation("AdminTCLeads")
  callLogs         CallLog[]   @relation("AdminTCCallLogs")
}

model Telecaller {
  id                String             @id @default(uuid())
  username          String
  firstName         String
  lastName          String?
  fatherOrHusband   String?
  gender            Gender?
  bloodGroup        BloodGroup?
  position          String?
  income            Float?
  academicQual      String?
  languages         String[]
  maritalStatus     String?
  spouseName        String?
  spousePhone       String?
  image             String?
  dob               DateTime?
  phone             String
  email             String
  password          String
  aadharCard        String?
  aadharNo          String?
  panCard           String?
  panNo             String?
  nomineeName       String?
  nomineePhone      String?
  nomineeRelation   String?
  addressLine       String?
  landmark          String?
  pinCode           String?
  city              String?
  state             String?
  country           String?
  alternativePhone  String?
  bankName          String?
  branch            String?
  accountHolder     String?
  bankAccountNo     String?
  ifsc              String?
  referId           String?
  createdById       String
  companyId         String
  roleId            String
  userAuthId        String?
  teamHeadId        String?
  reasonForReject   String?
  status            StatusType         @default(PENDING)
  passwordChanged   Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  company           Company            @relation(fields: [companyId], references: [id])
  role              Role               @relation(fields: [roleId], references: [id])

  // CRM Relations
  leads             Lead[]             @relation("TelecallerTableLeads")
  callLogs          CallLog[]          @relation("TelecallerTableCallLogs")
  activities        Activity[]         @relation("TelecallerActivities")
  notifications     Notification[]     @relation("TelecallerNotifications")
  pushNotifications PushNotification[] @relation("TelecallerPushNotifications")
  notes             Note[]             @relation("TelecallerNotes")
  meetings          Meeting[]          @relation("TelecallerMeetings")
  reminders         Reminder[]         @relation("TelecallerReminders")
  siteVisits        SiteVisit[]        @relation("TelecallerSiteVisits")
  followUps         FollowUp[]         @relation("TelecallerFollowUps")

  // Trackers
  availability       String    @default("AVAILABLE")
  isOnline           Boolean   @default(false)
  mustChangePassword Boolean   @default(true)
  lastLoginAt        DateTime?
  lastActiveAt       DateTime?
  performanceScore   Float     @default(0)

  @@index([companyId])
  @@index([roleId])
  @@index([status])
  @@index([email])
}

model ClientAdmin {
  id                String      @id @default(uuid())
  username          String
  firstName         String
  lastName          String?
  fatherOrHusband   String?
  gender            Gender?
  bloodGroup        BloodGroup?
  image             String?
  dob               DateTime?
  phone             String
  email             String
  password          String
  aadharNo          String?
  panNo             String?
  nomineeName       String?
  nomineePhone      String?
  nomineeRelation   String?
  addressLine       String?
  city              String?
  state             String?
  pinCode           String?
  country           String?
  bankName          String?
  branch            String?
  accountHolder     String?
  bankAccountNo     String?
  ifsc              String?
  companyId         String
  status            AdminStatus @default(PENDING)
  passwordChanged   Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  company           Company     @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([email])
}


model Company {
  id                 String                @id @default(uuid())
  company            String
  address            String?
  img                String?
  phone              String
  email              String                @unique
  openingBalance     Float?
  openingBalanceType BalanceType?
  openingBalanceDate DateTime?
  status             CompanyStatus
  modules            String[]
  domain             String?               @unique
  primaryColour      String?
  secondaryColour    String?
  authIdType         AuthIdGenerationType?
  authIdPrefix       String?
  companyTerm        String?
  transactionPrefix  String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  followUps          FollowUp[]
  galleries          Gallery[]
  projectStatuses    ProjectStatus[]
  news               News[]
  notes              Note[]
  notifications      Notification[]
  plots              Plot[]
  portraits          Portrait[]
  projects           Project[]
  pushNotifications  PushNotification[]
  roles              Role[]
  showcases          Showcase[]
  users              User[]
  admins             Admin[]
  telecallers        Telecaller[]
  videos             Video[]
  accountTrees       AccountTree[]
  ledgers            Ledger[]
  subledgers         SubLedger[]
  parties            Party[]
  transactions       Transaction[]
  transactionEntries TransactionEntry[]
  payments           Payment[]
  banks              Bank[]
  chequeSeries       ChequeSeries[]
  transactionModeDetails TransactionModeDetail[]
  chequeDetails      ChequeDetail[]
  financeLogs        FinanceLog[]
  clientAdmins       ClientAdmin[]
  associateContributions AssociateContribution[]
  vehicles           Vehicle[]
  vehicleSiteVisits  VehicleSiteVisit[]

  @@index([status])
}

model News {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  time        String
  newsPicture String?
  type        NewsType
  companyId   String
  source      String?
  heading     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([date])
}

model FollowUp {
  id             String           @id @default(uuid())
  userId         String
  leadName       String
  leadPhone      String?
  leadEmail      String?
  date           DateTime
  time           String
  followUpType   String?
  projectId      String?
  followUpStatus FollowUpStatus?
  priority       FollowUpPriority
  comment        String?
  companyId      String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  company        Company          @relation(fields: [companyId], references: [id])
  project        Project?         @relation(fields: [projectId], references: [id])
  user           User?            @relation("UserFollowUps", fields: [userId], references: [id])
  telecallerId   String?
  telecaller     Telecaller?      @relation("TelecallerFollowUps", fields: [telecallerId], references: [id])

  @@index([userId])
  @@index([companyId])
  @@index([projectId])
  @@index([date])
}

model Gallery {
  id           String        @id @default(uuid())
  fileName     String
  fileCategory String
  companyId    String
  status       GalleryStatus
  scheduledAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company       @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
}

model Notification {
  id               String   @id @default(uuid())
  userId           String
  title            String
  body             String
  notificationType String
  timeStamp        DateTime @default(now())
  status           String
  companyId        String
  companyName      String
  isRead           Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id])
  user             User?    @relation("UserNotifications", fields: [userId], references: [id])
  telecallerId     String?
  telecaller       Telecaller? @relation("TelecallerNotifications", fields: [telecallerId], references: [id])

  @@index([userId])
  @@index([companyId])
  @@index([isRead])
  @@index([timeStamp])
}

model Portrait {
  id          String   @id @default(uuid())
  videoTitle  String
  videoName   String?
  videoLink   String
  companyId   String
  status      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Phase {
  id        String   @id @default(uuid())
  phaseName String?
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id])
  plots     Plot[]

  @@index([projectId])
}

model Project {
  id                     String        @id @default(uuid())
  projectName            String
  projectDescription     String?
  projectAddress         String
  projectImage           String?
  projectWebsiteUrl      String?
  projectVirtualViewLink String?
  layoutImage            String[]
  brochures              String[]
  qrCode                 String[]
  images                 String[]
  highlights             String[]
  approvals              String[]
  approvalCopies         String[]
  sliders                String[]
  flyers                 String[]
  videos                 String[]
  locationHighlights     String[]
  companyId              String
  projectStatusId        String        @map("highwayId")
  latitude               String?
  longitude              String?
  incentivesLevel        Json?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  followUps              FollowUp[]
  leads                  Lead[]
  phases                 Phase[]
  plots                  Plot[]
  siteVisits             SiteVisit[]
  company                Company       @relation(fields: [companyId], references: [id])
  projectStatus          ProjectStatus @relation(fields: [projectStatusId], references: [id])
  transactions           Transaction[]

  @@index([companyId])
  @@index([projectStatusId])
}

model Plot {
  id                  String    @id @default(uuid())
  phaseId             String?
  plotCategory        String
  facing              String?
  sqrYards            Float
  plotNumber          String
  projectName         String
  projectId           String
  plotStatus          String?
  customerName        String?
  customerContact     String?
  customerAddress     String?
  latitude            String?
  longitude           String?
  plotBookingNumber   String?
  plotBookingPlan     String?
  status              String
  paymentType         String?
  paymentStatus       String?
  companyId           String
  totalCost           String?
  paidAmount          String?
  remainingAmount     String?
  paymentImage        String?
  paymentMode         String?
  aadhar              String?
  referId             String?
  teamHeadId          String?
  associateId         String?
  associateUserAuthId String?
  reasonForRejection  String?
  point               String?
  pbNumber            String?
  bookingDate         DateTime?
  registeredDate      DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  company             Company   @relation(fields: [companyId], references: [id])
  phase               Phase?    @relation(fields: [phaseId], references: [id])
  project             Project   @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([phaseId])
  @@index([companyId])
  @@index([plotStatus])
}

model ProjectStatus {
  id          String    @id @default(uuid())
  statusName  String    @map("highwayName")
  statusIcon  String?   @map("highwayIcon")
  companyId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id])
  projects    Project[]

  @@index([companyId])
  @@map("Highway")
}


model Note {
  id              String   @id @default(uuid())
  noteTitle       String?
  noteDescription String?
  userId          String
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company  @relation(fields: [companyId], references: [id])
  user            User?      @relation("UserNotes", fields: [userId], references: [id])
  telecallerId    String?
  telecaller      Telecaller? @relation("TelecallerNotes", fields: [telecallerId], references: [id])

  @@index([userId])
  @@index([companyId])
}

model Lead {
  id                    String    @id @default(uuid())
  userId                String
  leadName              String
  leadContact           String
  leadEmail             String?
  leadCity              String?
  leadOccupation        String?
  leadCompany           String?
  leadAge               Int?
  gender                Gender?
  maritalStatus         String?
  additionalInformation String?
  date                  DateTime
  description           String?
  leadSource            String
  leadStatus            String
  firstInteractionDate  DateTime?
  leadCategory          String?
  projectInterestedIn   String?
  observations          String?
  followUpDate          DateTime?
  assignedTo            String?
  notes                 String?
  companyId             String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  project               Project?  @relation(fields: [projectInterestedIn], references: [id])
  user                  User      @relation("UserLeads", fields: [userId], references: [id])

  // --- LEADFLOW CRM FIELDS (Safe Appends) ---
  assocStatus String?

  // Leadflow Assignments
  // original (Keeping this to prevent data loss during migration)
  telecallerId String?
  telecaller   User?   @relation("UserLeadsTC", fields: [telecallerId], references: [id])

  // NEW: Dedicated Telecaller table
  dedicatedTCId String?
  dedicatedTC   Telecaller? @relation("TelecallerTableLeads", fields: [dedicatedTCId], references: [id])
  
  // NEW: Admin (for Telecaller Admins)
  adminTCId     String?
  adminTC       Admin?      @relation("AdminTCLeads", fields: [adminTCId], references: [id])

  associateId  String?
  associate    User?   @relation("AssociateLeads", fields: [associateId], references: [id])
  assignedById String?
  assignedBy   User?   @relation("AdminAssignments", fields: [assignedById], references: [id])

  callLogs CallLog[]
  meetings Meeting[]

  @@index([userId])
  @@index([projectInterestedIn])
  @@index([leadStatus])
  @@index([date])
}

model Reminder {
  id           String     @id @default(uuid())
  userId       String
  type         String
  description  String
  date         DateTime
  time         String
  repeat       RepeatType
  selectedDays String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User?      @relation("UserReminders", fields: [userId], references: [id])
  telecallerId String?
  telecaller   Telecaller? @relation("TelecallerReminders", fields: [telecallerId], references: [id])

  @@index([userId])
  @@index([date])
}

model Request {
  id            String        @id @default(uuid())
  requestType   String
  userId        String
  requestedById String
  requestedName String
  message       String?
  timestamp     DateTime
  status        RequestStatus
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  requestBy     User          @relation("UserRequestedBy", fields: [requestedById], references: [id])
  user          User          @relation("UserRequests", fields: [userId], references: [id])

  @@index([userId])
  @@index([requestedById])
  @@index([status])
}

model SuperAdmin {
  id                 String     @id @default(uuid())
  username           String
  address            String?
  image              String?
  phone              String
  email              String
  password           String
  role               String
  status             StatusType
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  firstName          String
  lastName           String?
  passwordChanged    Boolean
  roleName           String
  tempPassToken      String?
  tempTokenExpiredAt DateTime?
  userAuthId         String?
}

model Role {
  id          String     @id @default(uuid())
  roleName    String
  roleNo      Int?
  displayName String
  status      RoleStatus
  companyId   String
  companyName String
  modules     String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company    @relation(fields: [companyId], references: [id])
  users       User[]
  admins      Admin[]
  telecallers Telecaller[]

  @@index([companyId])
  @@index([status])
}

model Showcase {
  id           String     @id @default(uuid())
  fileName     String
  fileCategory String
  platform     String
  companyId    String
  status       StatusType
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  company      Company    @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model SiteVisit {
  id               String   @id @default(uuid())
  userId           String
  leadName         String
  phone            String
  date             DateTime
  time             String
  siteVisitPicture String?
  projectId        String?
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy       String?
  changeLog        String?
  project          Project? @relation(fields: [projectId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User?    @relation("UserSiteVisits", fields: [userId], references: [id])
  telecallerId     String?
  telecaller       Telecaller? @relation("TelecallerSiteVisits", fields: [telecallerId], references: [id])

  @@index([userId])
  @@index([date])
}

model PushNotification {
  id            String   @id @default(uuid())
  userId        String
  fcmToken      String
  lastRequest   DateTime @default(now())
  timeStamp     DateTime @default(now())
  checkActivity DateTime @default(now())
  status        String
  companyId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])
  user          User?    @relation("UserPushNotifications", fields: [userId], references: [id])
  telecallerId  String?
  telecaller    Telecaller? @relation("TelecallerPushNotifications", fields: [telecallerId], references: [id])

  @@index([userId])
  @@index([companyId])
}

model Video {
  id          String   @id @default(uuid())
  videoTitle  String
  videoName   String
  videoLink   String
  companyId   String
  status      String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model EventLog {
  id                String   @id @default(uuid())
  category          String
  actionBy          String
  actionDescription String
  timeStamp         DateTime @default(now())
  companyId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([companyId])
  @@index([timeStamp])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
}

enum StatusType {
  VERIFIED
  PENDING
  NONE
}

enum EmploymentType {
  PERMANENT
  CONTRACT
}

enum UserStatus {
  VERIFIED
  PENDING
  REJECT
  HOLD
  INACTIVE
}

enum AdminStatus {
  VERIFIED
  PENDING
  NONE
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum BalanceType {
  CREDIT
  DEBIT
}

enum AuthIdGenerationType {
  MANUAL
  AUTO
}

enum NewsType {
  GENERAL
  DAILY
  INDUSTRY
}

enum FollowUpStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum FollowUpPriority {
  LOW
  MEDIUM
  HIGH
}

enum GalleryStatus {
  ACTIVE
  INACTIVE
  SCHEDULED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RepeatType {
  DAILY
  WEEKLY
  MONTHLY
  NONE
}

enum RoleStatus {
  ACTIVE
  INACTIVE
}

// ============== FINANCE MODULE MODELS ==============

model AccountTree {
  id        String        @id @default(uuid())
  name      String
  code      String
  parentId  String?
  type      AccountType // ASSET, LIABILITY, INCOME, EXPENSE
  companyId String
  status    FinanceStatus @default(ACTIVE)
  company   Company       @relation(fields: [companyId], references: [id])
  parent    AccountTree?  @relation("AccountTreeHierarchy", fields: [parentId], references: [id])
  children  AccountTree[] @relation("AccountTreeHierarchy")
  ledgers   Ledger[]

  @@unique([code, companyId])
}

model Ledger {
  id                 String             @id @default(uuid())
  name               String
  accountTreeId      String
  companyId          String
  bifurcated         Boolean?
  status             FinanceStatus      @default(ACTIVE)
  accountTree        AccountTree        @relation(fields: [accountTreeId], references: [id])
  company            Company            @relation(fields: [companyId], references: [id])
  subledgers         SubLedger[]
  transactionEntries TransactionEntry[]
}

model SubLedger {
  id                 String             @id @default(uuid())
  name               String
  ledgerId           String
  companyId          String
  status             FinanceStatus      @default(ACTIVE)
  ledger             Ledger             @relation(fields: [ledgerId], references: [id])
  company            Company            @relation(fields: [companyId], references: [id])
  transactionEntries TransactionEntry[]
}

model Party {
  id           String        @id @default(uuid())
  name         String
  email        String?
  phone        String?
  address      String?
  panNumber    String?
  gstNumber    String?
  type         PartyType // VENDOR, CUSTOMER, EMPLOYEE, OTHER
  companyId    String
  transactions Transaction[]
  company      Company       @relation(fields: [companyId], references: [id])
}

model Transaction {
  id                    String             @id @default(uuid())
  transactionType       TransactionType // RECEIPT, PAYMENT, JOURNAL, CHEQUE_ISSUE
  transactionDate       DateTime
  referenceNumber       String?            @unique
  narration             String?
  totalAmount           Float
  status                TransactionStatus  @default(ACTIVE)
  companyId             String
  createdById           String
  relatedTransactionId  String?
  partyId               String?
  projectId             String?
  documentUrl           String?
  company               Company            @relation(fields: [companyId], references: [id])
  createdBy             User               @relation(fields: [createdById], references: [id])
  relatedTransaction    Transaction?       @relation("RelatedTransactions", fields: [relatedTransactionId], references: [id])
  relatedByTransactions Transaction[]      @relation("RelatedTransactions")
  party                 Party?             @relation(fields: [partyId], references: [id])
  project               Project?           @relation(fields: [projectId], references: [id])
  entries               TransactionEntry[]
  modeDetails           TransactionModeDetail[]
  chequeDetails         ChequeDetail[]

  @@index([status])
  @@index([companyId])
  @@index([transactionType])
}

model TransactionEntry {
  id               String        @id @default(uuid())
  transactionId    String
  ledgerId         String
  subledgerId      String?
  amount           Float
  entryType        EntryType // DEBIT, CREDIT
  narration        String?
  tdsTaxPercentage Float?
  tdsTaxAmount     Float?
  gstTaxPercentage Float?
  gstTaxAmount     Float?
  isTaxInclusive   Boolean?
  companyId        String
  status           FinanceStatus @default(ACTIVE)
  transaction      Transaction   @relation(fields: [transactionId], references: [id])
  ledger           Ledger        @relation(fields: [ledgerId], references: [id])
  subledger        SubLedger?    @relation(fields: [subledgerId], references: [id])
  company          Company       @relation(fields: [companyId], references: [id])
}

model Payment {
  id            String  @id @default(uuid())
  project       String
  accountNumber String
  accountName   String
  paymentQRcode String
  companyId     String
  company       Company @relation(fields: [companyId], references: [id])
}

model Bank {
  id            String  @id @default(uuid())
  name          String
  accountNumber String?
  ifscCode      String?
  branch        String?
  companyId     String
  company       Company @relation(fields: [companyId], references: [id])
  modeDetails   TransactionModeDetail[]
  
  @@index([companyId])
}

model ChequeSeries {
  id          String   @id @default(uuid())
  startNumber String
  endNumber   String
  currentNumber String
  bankId      String
  companyId   String
  status      String   @default("ACTIVE") // ACTIVE, EXHAUSTED
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

model TransactionModeDetail {
  id                 String    @id @default(uuid())
  transactionId      String
  accountNumber      String?
  accountHolderName  String?
  ifscCode           String?
  bankBranch         String?
  cardType           String?
  cardProvider       String?
  type               String    // RECEIVED, ISSUED
  mode               String    // CASH, CHEQUE, ONLINE, CARD
  amount             Float
  bankName           String?
  companyBankId      String?
  onlineType         String?   // NEFT, RTGS, IMPS, UPI, etc.
  upiId              String?
  referenceNumber    String?
  cardNumber         String?
  chequeNumber       String?
  chequeDate         DateTime?
  transactionDate    DateTime
  narration          String?
  status             String    @default("ACTIVE")
  companyId          String
  createdById        String
  transaction        Transaction @relation(fields: [transactionId], references: [id])
  companyBank        Bank?        @relation(fields: [companyBankId], references: [id])
  company            Company      @relation(fields: [companyId], references: [id])
  chequeDetails      ChequeDetail[]
  
  @@index([transactionId])
  @@index([companyId])
}

model ChequeDetail {
  id                      String    @id @default(uuid())
  transactionId           String
  transactionModeDetailId String
  status                  String    // RECEIVED, ISSUED, CANCELLED, CLEARED, BOUNCED
  remarks                 String?
  companyId               String
  createdById             String
  chequeType              String    // RECEIVED, ISSUED
  chequeNumber            String
  transaction             Transaction @relation(fields: [transactionId], references: [id])
  modeDetail              TransactionModeDetail @relation(fields: [transactionModeDetailId], references: [id])
  company                 Company     @relation(fields: [companyId], references: [id])
  
  @@index([transactionId])
  @@index([companyId])
}

model FinanceLog {
  id                String   @id @default(uuid())
  action            String   // CREATE, UPDATE, DELETE, VIEW_REPORT
  module            String   // GENERAL_RECEIPT, PAYMENT_VOUCHER, etc.
  recordId          String?
  userId            String
  username          String
  companyId         String
  description       String
  details           Json?
  createdAt         DateTime @default(now())
  company           Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([userId])
}

enum AccountType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
}

enum TransactionType {
  RECEIPT
  PAYMENT
  JOURNAL
  CHEQUE_ISSUE
}

enum TransactionStatus {
  ACTIVE
  CANCELLED
}

enum EntryType {
  DEBIT
  CREDIT
}

enum PartyType {
  VENDOR
  CUSTOMER
  EMPLOYEE
  OTHER
}

enum FinanceStatus {
  ACTIVE
  INACTIVE
}

// ============== LEADFLOW CRM MODULE ==============

model CallLog {
  id           String    @id @default(cuid())
  leadId       String
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  // Legacy field for migration safety
  telecallerId      String?
  telecaller        User?      @relation("UserCallLogs", fields: [telecallerId], references: [id])
  
  // New fields
  dedicatedTCId     String?
  dedicatedTC       Telecaller? @relation("TelecallerTableCallLogs", fields: [dedicatedTCId], references: [id])
  adminTCId         String?
  adminTC           Admin?      @relation("AdminTCCallLogs", fields: [adminTCId], references: [id])
  status       String
  notes        String?
  callbackAt   DateTime?
  createdAt    DateTime  @default(now())

  @@map("call_logs")
}

model Meeting {
  id            String    @id @default(cuid())
  leadId        String
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  associateId   String
  associate     User       @relation("UserMeetings", fields: [associateId], references: [id])
  telecallerId  String?
  telecaller    Telecaller? @relation("TelecallerMeetings", fields: [telecallerId], references: [id])
  outcome       String
  meetingDate   DateTime?
  notes         String?
  interested    String?
  bookingStatus String?
  followUpDate  DateTime?
  createdAt     DateTime  @default(now())

  @@map("meetings")
}

model Activity {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation("UserActivities", fields: [userId], references: [id])
  telecallerId String?
  telecaller   Telecaller? @relation("TelecallerActivities", fields: [telecallerId], references: [id])
  text      String
  color     String   @default("#3b82f6")
  createdAt DateTime @default(now())

  @@map("activities")
}
// ============== ASSOCIATE FINANCE MODULE ==============

model AssociateContribution {
  id                String             @id @default(uuid())
  empName           String             @map("emp_name")
  empId             String             @map("emp_id")
  empUserAuthId     String             @map("emp_user_auth_id")
  teamHeadId        String?            @map("team_head_id")
  projectId         String?            @map("project_id")
  plotId            String             @map("plot_id")
  plotNumber        String             @map("plot_number")
  sqrYards          String             @map("sqr_yards")
  pricePerSqYard    Int                @map("price_per_sq_yard")
  plotPrice         String             @map("plot_price")
  totalAmount       Float              @map("total_amount")
  soldBy            String?            @map("sold_by")
  roleId            String?            @map("role")
  roleName          String             @map("role_name")
  level             String?
  saleType          String?            @map("sale_type")
  companyId         String             @map("company_id")
  status            ContributionStatus @default(PENDING)
  manualOverride    Boolean            @default(false) @map("manual_override")
  overrideReason    String?            @map("override_reason")
  commissionAmount  Float?             @map("commission_amount")
  notes             String?
  payoutDate        DateTime?          @map("payout_date")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  company           Company            @relation(fields: [companyId], references: [id])
  payouts           AssociatePayout[]

  @@index([empId])
  @@index([companyId])
  @@index([plotId])
}

model AssociateExpense {
  id              String         @id @default(uuid())
  associateId     String         @map("associate_id")
  associateName   String         @map("associate_name")
  userAuthId      String         @map("user_auth_id")
  teamHeadName    String         @map("team_head_name")
  teamHeadId      String         @map("team_head_id")
  date            DateTime
  expenseType     String         @map("expense_type")
  siteVisitId     String?        @map("sitevisit_id")
  amountSpent     Float          @map("amount_spent")
  description     String?
  companyId       String         @map("company_id")
  paymentReceipt  String?        @map("payment_receipt")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([associateId])
  @@index([companyId])
}

model AssociatePayout {
  id             String                @id @default(uuid())
  associateId    String                @map("associate_id")
  contributionId String?               @map("contribution_id")
  amountPaid     Float                 @map("amount_paid")
  payoutDate     DateTime              @map("payout_date")
  paymentMode    String?               @map("payment_mode")
  transactionId  String?               @map("transaction_id")
  notes          String?
  companyId      String                @map("company_id")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  contribution   AssociateContribution? @relation(fields: [contributionId], references: [id])

  @@index([associateId])
  @@index([companyId])
}

enum ContributionStatus {
  PAID
  PENDING
  REJECT
  HOLD
}

model Vehicle {
  id              String             @id @default(uuid())
  vehicleName     String
  vehicleNumber   String
  vehicleType     String             // Bus, Car, Bike, etc.
  driverName      String?
  driverPhone     String?
  status          String             @default("AVAILABLE") // AVAILABLE, ON_TRIP, MAINTENANCE
  companyId       String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  company         Company            @relation(fields: [companyId], references: [id])
  trips           VehicleSiteVisit[]

  @@index([companyId])
}

model VehicleSiteVisit {
  id               String    @id @default(uuid())
  vehicleId        String?
  associateId      String
  associateName    String
  userAuthId       String?
  teamHeadName     String?
  teamHeadId       String?
  date             DateTime
  totalAmountSpent Float     @default(0)
  totalKms         String?
  startKms         String?
  endKms           String?
  projects         Json      // Array of project details
  status           String    @default("PENDING") // PENDING, APPROVED, COMPLETED, REJECTED
  financeStatus    String    @default("UNPAID")  // UNPAID, PAID
  approvedBy       String?
  paymentReceipt   String?
  companyId        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  vehicle          Vehicle?  @relation(fields: [vehicleId], references: [id])
  company          Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([associateId])
}
